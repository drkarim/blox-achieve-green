# ─────────────────────────────────────────────────────────────────────────────
# Level Up Portal — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these in the service's Variables panel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL / PlanetScale / Railway MySQL connection string.
# Railway auto-injects this when you attach a MySQL plugin to the service.
DATABASE_URL=mysql://user:password@host:3306/level_up_portal

# ── Auth / Session ────────────────────────────────────────────────────────────
# A long random secret used to sign JWT session cookies.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret

# ── App identity (used inside JWT payload) ────────────────────────────────────
# Any unique string that identifies this deployment (e.g. "level-up-portal").
# Does NOT need to be a real Manus app ID when self-hosting.
VITE_APP_ID=level-up-portal

# ── Manus OAuth (only needed if you want Manus SSO login) ────────────────────
# Leave these blank to disable Manus OAuth and use username/password only.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# ── Manus built-in APIs (optional — only needed on Manus platform) ────────────
# Leave blank when self-hosting; the app works without them.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Owner info (optional) ─────────────────────────────────────────────────────
OWNER_OPEN_ID=
OWNER_NAME=

# ── Analytics (optional) ─────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
